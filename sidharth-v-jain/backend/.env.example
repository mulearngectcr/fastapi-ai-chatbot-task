# Required: get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: if set, /chat and /clear require an "X-API-Key" header with this value
BACKEND_API_KEY=

# Optional: gives the bot a personality. Falls back to a default if unset.
SYSTEM_PROMPT=You are a friendly, concise assistant with a warm sense of humor.
